```gitignore
# Compiled Python files
*.pyc
__pycache__/

# Dependencies
.venv/
venv/
env/
pip-log.txt
pip-selfcheck.json

# Logs
*.log

# Environment variables
.env
.env.local
*.env.*

# Coverage reports
.coverage
coverage/
htmlcov/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Build outputs
build/
dist/
*.egg-info/
```